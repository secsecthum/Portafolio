# --- CONFIGURACIÓN DE DOMINIO Y SSL ---
# El dominio principal donde correrá el CRM (ej: misistema.com)
DOMAIN=localhost.com
# Email para que Let's Encrypt te avise si el certificado va a caducar
EMAIL_LETSENCRYPT=secsecthum@gmail.com

# --- CONFIGURACIÓN DE BASE DE DATOS (MariaDB) ---
MYSQL_ROOT_PASSWORD=password_root_super_seguro
MYSQL_DATABASE=espocrm
MYSQL_USER=espouser
MYSQL_PASSWORD=espouser_password_seguro

# --- CONFIGURACIÓN DE ESPOCRM ---
# Credenciales para el primer inicio de sesión como administrador
ESPO_ADMIN_USER=admin
ESPO_ADMIN_PASS=admin_password_123

# --- CONFIGURACIÓN DE MONITOREO (Grafana) ---
# Usuario y clave para entrar al panel de métricas
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASS=grafana_password_seguro

# --- CONFIGURACIÓN DE RED (Opcional) ---
# Si necesitas cambiar el puerto interno de Traefik para pruebas locales
TRAEFIK_DASHBOARD_PORT=8088